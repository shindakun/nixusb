# Nix build output (dead symlink into the container store once it exits)
/result
result-*

# Built ISO artifacts (large; rebuild with `make iso`)
*.iso

# NOTE: hosts/*/hardware-configuration.nix is intentionally COMMITTED (not
# ignored). Committing each machine's real hardware config means a fresh clone
# is install-ready and `git pull` never wipes it. Generate a new host's once
# with `nixos-generate-config --show-hardware-config` then commit it.

# macOS / editor cruft
.DS_Store
*.swp
